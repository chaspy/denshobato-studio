{
  "name": "@denshobato-studio/ui",
  "version": "0.1.0",
  "description": "React UI overlay for Denshobato Studio - chat, element selector, diff viewer, PR dialog",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./inject": {
      "import": "./dist/inject.js",
      "require": "./dist/inject.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chaspy/denshobato-studio.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/chaspy/denshobato-studio#readme",
  "bugs": "https://github.com/chaspy/denshobato-studio/issues",
  "keywords": ["ai", "react", "ui-editing", "overlay", "denshobato"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
