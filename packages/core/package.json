{
  "name": "@denshobato-studio/core",
  "version": "0.1.0",
  "description": "LLM integration, file operations, session management, and GitHub integration for Denshobato Studio",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chaspy/denshobato-studio.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/chaspy/denshobato-studio#readme",
  "bugs": "https://github.com/chaspy/denshobato-studio/issues",
  "keywords": ["ai", "llm", "claude", "react", "ui-editing", "code-generation", "denshobato"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@octokit/rest": "^21.0.0",
    "diff": "^7.0.0",
    "glob": "^11.0.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
